{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/market_scan.schema.json",
  "title": "Market Scan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "scan_id",
    "created_at",
    "created_by",
    "initiative_name",
    "problem_domain",
    "target_geographies",
    "target_segments",
    "demand_signals",
    "market_trends",
    "opportunity_summary",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "artifact_type": {
      "const": "market_scan"
    },
    "scan_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "initiative_name": {
      "type": "string",
      "minLength": 3
    },
    "problem_domain": {
      "type": "string",
      "minLength": 10
    },
    "target_geographies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "target_segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment_name", "pain_severity", "buyer_type"],
        "properties": {
          "segment_name": { "type": "string", "minLength": 2 },
          "pain_severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "buyer_type": { "type": "string", "minLength": 2 },
          "urgency_drivers": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 }
          }
        }
      }
    },
    "demand_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal", "signal_type", "strength"],
        "properties": {
          "signal": { "type": "string", "minLength": 5 },
          "signal_type": {
            "type": "string",
            "enum": ["search_interest", "buyer_feedback", "budget_shift", "regulatory_pressure", "workflow_breakdown", "trend_observation"]
          },
          "strength": {
            "type": "string",
            "enum": ["weak", "moderate", "strong"]
          },
          "evidence_note": { "type": "string", "minLength": 5 }
        }
      }
    },
    "market_trends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trend", "direction", "relevance"],
        "properties": {
          "trend": { "type": "string", "minLength": 5 },
          "direction": {
            "type": "string",
            "enum": ["accelerating", "stable", "declining", "uncertain"]
          },
          "relevance": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "impact_note": { "type": "string" }
        }
      }
    },
    "tam_sam_som": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tam_estimate": { "type": "number", "minimum": 0 },
        "sam_estimate": { "type": "number", "minimum": 0 },
        "som_estimate": { "type": "number", "minimum": 0 },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "estimation_note": { "type": "string" }
      }
    },
    "opportunity_summary": {
      "type": "string",
      "minLength": 20
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  }
}