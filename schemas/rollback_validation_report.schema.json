{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/rollback_validation_report.schema.json",
  "title": "Rollback Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "report_id",
    "created_at",
    "created_by",
    "task_id",
    "rollback_ref",
    "validated_target_state",
    "validation_checks",
    "overall_status",
    "safe_to_close"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "artifact_type": {
      "const": "rollback_validation_report"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "rollback_ref": {
      "type": "string",
      "minLength": 1
    },
    "validated_target_state": {
      "type": "string",
      "minLength": 2
    },
    "validation_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_name", "result"],
        "properties": {
          "check_name": {
            "type": "string",
            "minLength": 3
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "warning"]
          },
          "evidence": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "severity", "mitigation"],
        "properties": {
          "risk": {
            "type": "string",
            "minLength": 5
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "mitigation": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "overall_status": {
      "type": "string",
      "enum": ["pass", "fail", "warning"]
    },
    "safe_to_close": {
      "type": "boolean"
    },
    "follow_up_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "notes": {
      "type": "string"
    }
  }
}