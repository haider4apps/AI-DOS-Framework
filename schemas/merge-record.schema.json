{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/merge-record.schema.json",
  "title": "MergeRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "merge_id", "source_branch", "target_branch", "merge_commit_sha", "merged_at", "merged_by", "strategy"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]{6}$"},
    "merge_id": {"type": "string", "pattern": "^MRG-[0-9]{6}-[0-9]{2}$"},
    "source_branch": {"type": "string", "minLength": 1, "maxLength": 200},
    "target_branch": {"type": "string", "minLength": 1, "maxLength": 200},
    "merge_commit_sha": {"type": "string", "minLength": 6, "maxLength": 64},
    "merged_at": {"type": "string", "format": "date-time"},
    "merged_by": {"type": "string", "minLength": 1, "maxLength": 100},
    "strategy": {"type": "string", "enum": ["merge", "squash", "rebase"]}
  }
}