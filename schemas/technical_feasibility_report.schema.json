{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.io/schemas/technical_feasibility_report.schema.json",
  "title": "Technical Feasibility Report",
  "description": "Estimation of time, tech stack, and technical blockers.",
  "type": "object",
  "properties": {
    "recommended_tech_stack": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Languages, frameworks, and databases required."
    },
    "estimated_effort": {
      "type": "object",
      "properties": {
        "days": { "type": "integer" },
        "hours": { "type": "integer" }
      },
      "required": ["days", "hours"]
    },
    "external_dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Third-party APIs or libraries needed."
    },
    "technical_risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Potential technical blockers or challenges."
    }
  },
  "required": [
    "recommended_tech_stack",
    "estimated_effort"
  ],
  "additionalProperties": false
}
