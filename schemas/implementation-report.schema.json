{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/implementation-report.schema.json",
  "title": "ImplementationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "produced_by",
    "request_id",
    "state",
    "status",
    "summary",
    "touched_files",
    "diff_summary",
    "handoff"
  ],
  "properties": {
    "artifact_type": {
      "const": "ImplementationReport"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "produced_by": {
      "type": "string",
      "const": "05_Coder"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "const": "IMPLEMENTING"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "no_changes"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "touched_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "diff_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "change_type", "summary"],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "change_type": {
            "type": "string",
            "enum": ["create", "modify", "delete", "rename", "none"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "no_op_reason": {
      "type": "string"
    },
    "tests_recommended": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ready_for_review", "reviewer_focus"],
      "properties": {
        "ready_for_review": {
          "type": "boolean"
        },
        "reviewer_focus": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "completed" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "handoff": {
            "properties": {
              "ready_for_review": { "const": true }
            },
            "required": ["ready_for_review"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "blocked" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["blockers"],
        "properties": {
          "blockers": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "no_changes" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["no_op_reason"]
      }
    }
  ]
}