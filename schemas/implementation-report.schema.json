{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/implementation-report.schema.json",
  "title": "ImplementationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "commit_shas", "files_changed", "plan_step_status", "deviations", "scope_delta"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]{6}$"},
    "commit_shas": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 6, "maxLength": 64}, "uniqueItems": true},
    "files_changed": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "plan_step_status": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "status"],
        "properties": {
          "step_id": {"type": "string", "pattern": "^S[0-9]+$"},
          "status": {"type": "string", "enum": ["done", "partial", "blocked", "skipped"]},
          "notes": {"type": "string", "maxLength": 1000}
        }
      }
    },
    "deviations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
    "scope_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["out_of_scope_changes_detected", "new_paths"],
      "properties": {
        "out_of_scope_changes_detected": {"type": "boolean"},
        "new_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  }
}