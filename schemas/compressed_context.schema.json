{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/compressed_context.schema.json",
  "title": "Compressed Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "context_id",
    "created_at",
    "created_by",
    "source_context_refs",
    "objective_summary",
    "constraints",
    "relevant_facts",
    "open_questions",
    "compression_metrics",
    "prompt_payload",
    "ready_for_planning"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "artifact_type": {
      "const": "compressed_context"
    },
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "source_context_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objective_summary": {
      "type": "string",
      "minLength": 20
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "relevant_facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fact", "source_ref", "priority"],
        "properties": {
          "fact": {
            "type": "string",
            "minLength": 5
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "category": {
            "type": "string"
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issue", "status"],
        "properties": {
          "issue": {
            "type": "string",
            "minLength": 5
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved", "waived"]
          },
          "resolution_note": {
            "type": "string"
          }
        }
      }
    },
    "compression_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "reduction_ratio", "target_budget_tokens"],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "reduction_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "target_budget_tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "prompt_payload": {
      "type": "string",
      "minLength": 20
    },
    "ready_for_planning": {
      "type": "boolean"
    }
  }
}