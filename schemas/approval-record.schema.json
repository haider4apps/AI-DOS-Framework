{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/approval-record.schema.json",
  "title": "ApprovalRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "approval_id", "approved_by", "approved_at", "approved_scope_hash", "expires_at", "conditions"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]{6}$"},
    "approval_id": {"type": "string", "pattern": "^APR-[0-9]{6}-[0-9]{2}$"},
    "approved_by": {"type": "string", "minLength": 1, "maxLength": 100},
    "approved_at": {"type": "string", "format": "date-time"},
    "approved_scope_hash": {"type": "string", "pattern": "^sha256:[A-Fa-f0-9]{16,128}$"},
    "expires_at": {"type": "string", "format": "date-time"},
    "conditions": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}
  }
}