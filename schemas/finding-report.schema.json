{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/finding-report.schema.json",
  "title": "FindingReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "produced_by",
    "request_id",
    "state",
    "verdict",
    "summary",
    "findings",
    "handoff"
  ],
  "properties": {
    "artifact_type": {
      "const": "FindingReport"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "produced_by": {
      "type": "string",
      "const": "06_Reviewer"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["REVIEW_PENDING", "SECURITY_PENDING"]
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "changes_requested", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "minor", "major", "critical"]
          },
          "file": {
            "type": "string"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next_state"],
      "properties": {
        "next_state": {
          "type": "string",
          "enum": ["DONE", "IMPLEMENTING", "BLOCKED", "SECURITY_PENDING"]
        },
        "coder_focus": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verdict": { "const": "approve" }
        },
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "handoff": {
            "properties": {
              "next_state": { "enum": ["DONE", "SECURITY_PENDING"] }
            },
            "required": ["next_state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": { "const": "changes_requested" }
        },
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "handoff": {
            "properties": {
              "next_state": { "const": "IMPLEMENTING" }
            },
            "required": ["next_state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": { "const": "blocked" }
        },
        "required": ["verdict"]
      },
      "then": {
        "required": ["blockers"],
        "properties": {
          "blockers": {
            "minItems": 1
          },
          "handoff": {
            "properties": {
              "next_state": { "const": "BLOCKED" }
            },
            "required": ["next_state"]
          }
        }
      }
    }
  ]
}