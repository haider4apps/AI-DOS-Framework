{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dos.dev/schemas/context-bundle.schema.json",
  "title": "ContextBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "bundle_id", "sources", "facts", "contradictions", "confidence", "status"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]{6}$"},
    "bundle_id": {"type": "string", "pattern": "^CTX-[0-9]{6}-[0-9]{2}$"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "commit_sha", "relevance"],
        "properties": {
          "type": {"type": "string", "enum": ["doc", "code", "memory", "config", "policy"]},
          "path": {"type": "string", "minLength": 1, "maxLength": 500},
          "commit_sha": {"type": "string", "minLength": 6, "maxLength": 64},
          "last_modified": {"type": "string", "format": "date-time"},
          "relevance": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "source_refs"],
        "properties": {
          "id": {"type": "string", "pattern": "^F[0-9]+$"},
          "statement": {"type": "string", "minLength": 3, "maxLength": 1000},
          "source_refs": {"type": "array", "items": {"type": "integer", "minimum": 1}, "minItems": 1}
        }
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "doc_claim", "code_fact", "severity"],
        "properties": {
          "id": {"type": "string", "pattern": "^C[0-9]+$"},
          "doc_claim": {"type": "string", "minLength": 3, "maxLength": 1000},
          "code_fact": {"type": "string", "minLength": 3, "maxLength": 1000},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]}
        }
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"type": "string", "enum": ["resolved", "partial", "conflict"]}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "resolved"}}},
      "then": {"properties": {"contradictions": {"maxItems": 0}}}
    },
    {
      "if": {"properties": {"status": {"const": "conflict"}}},
      "then": {"properties": {"contradictions": {"minItems": 1}}}
    }
  ]
}